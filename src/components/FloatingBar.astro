---
import { MessageCircle } from 'lucide-react';
---

<div class="fixed bottom-0 left-0 w-full z-[60] px-4 pb-4 pointer-events-none">
  <div class="max-w-4xl mx-auto">
    <div class="bg-white/80 backdrop-blur-md border border-slate-200/50 rounded-2xl shadow-2xl p-2 md:p-3 pointer-events-auto flex items-center justify-between gap-4">
      <div class="flex items-center gap-2 md:gap-3 pl-1 md:pl-2">
        <!-- Desktop Only Status (Left) -->
        <div class="hidden md:flex items-center gap-1.5 bg-green-50 px-2 py-1 rounded-full border border-green-100">
          <div class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></div>
          <span class="text-[9px] font-bold text-green-600 uppercase tracking-wider whitespace-nowrap">En línea</span>
        </div>

        <!-- Mobile Only Green Dot (Left) -->
        <div class="flex md:hidden w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse shrink-0"></div>
        
        <p class="text-[9px] md:text-sm font-medium text-navy leading-tight">
          ¿Tienes dudas sobre el Máster?<br class="sm:hidden" /> Pregunta a un asesor:
        </p>
      </div>
      
      <div class="flex flex-col items-center gap-0.5">
        <a 
          href="https://wa.me/13072923715?text=Hola%2C%20tengo%20algunas%20dudas%20sobre%20el%20%2AM%C3%81STER%20EJECUTIVO%20EN%20ORGANIZACI%C3%93N%20DE%20EVENTOS%20%26%20WEDDING%20PLANNER%2A%20que%20vi%20en%20la%20p%C3%A1gina%20web" 
          target="_blank"
          class="flex items-center gap-2 bg-[#25D366] hover:bg-[#20ba5a] text-white px-3 py-2 md:px-6 md:py-2.5 rounded-xl text-[10px] md:text-sm font-bold shadow-lg shadow-green-500/20 transition-all transform hover:scale-[1.02] active:scale-[0.98] whitespace-nowrap"
        >
          <MessageCircle class="w-3 h-3 md:w-4 md:h-4" />
          <span>Consultar por WhatsApp</span>
        </a>
        
        <!-- Mobile Only Status (Under Button) -->
        <div class="flex md:hidden items-center gap-1 opacity-90">
          <div class="w-1 h-1 bg-green-500 rounded-full animate-pulse"></div>
          <span class="text-[7px] font-bold text-green-600 uppercase tracking-widest">En línea</span>
        </div>
      </div>
    </div>
  </div>
</div>
