---
import { BadgeCheck, Briefcase, GraduationCap, Timer, Clock, Smartphone, Landmark } from 'lucide-react';
---

<section class="relative min-h-screen flex items-center justify-center pt-20 pb-12 overflow-hidden">
  <!-- Dynamic Background with Overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src="https://images.unsplash.com/photo-1519741497674-611481863552?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80" 
      alt="Boda de lujo decorada con elegancia" 
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-navy/80 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-navy via-transparent to-transparent"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10 grid md:grid-cols-2 gap-12 items-center max-w-6xl">
    <!-- Left Column: Copy -->
    <div class="text-white space-y-6 text-center md:text-left mt-8 md:mt-0">
      <div class="flex flex-wrap gap-2 justify-center md:justify-start">
        <div class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur px-3 md:px-4 py-1 rounded-full border border-white/20 text-xs md:text-sm font-medium text-gold-light">
          <span class="animate-pulse text-[10px] md:text-xs">●</span> Cupos Limitados
        </div>
        <div class="inline-flex items-center gap-1.5 bg-blue-500/20 backdrop-blur px-2.5 md:px-3 py-1 rounded-full border border-blue-400/30 text-xs md:text-sm">
          <span class="text-xs md:text-base">🇺🇸</span>
          <span class="text-blue-200 font-medium">Edición USA</span>
        </div>
      </div>
      
      <h1 class="text-2xl md:text-4xl lg:text-6xl font-bold font-serif leading-tight">
        Máster Ejecutivo en Organización de Eventos & Wedding Planner
      </h1>
      
      <p class="text-lg md:text-2xl font-medium text-transparent bg-clip-text bg-gradient-to-r from-white via-slate-200 to-slate-400 max-w-lg mx-auto md:mx-0 drop-shadow-sm pb-1">
        Convierte tu Pasión en un <span class="text-gold italic font-bold">Negocio Rentable</span> con Aval Americano. Domina el arte de crear experiencias inolvidables.
      </p>

      <!-- Trust Badges -->
      <div class="flex flex-col md:flex-row gap-4 pt-4 justify-center md:justify-start">
        <div class="flex items-center gap-3 bg-navy-light/50 p-3 rounded-lg border border-white/10">
          <BadgeCheck class="text-blue-400 w-6 h-6 shrink-0" />
          <div class="text-left">
            <p class="text-[10px] text-slate-400 uppercase tracking-wider">Aval</p>
            <p class="font-semibold text-[11px] md:text-sm">Internacional EE.UU 🇺🇸</p>
          </div>
        </div>
        <div class="flex items-center gap-3 bg-navy-light/50 p-3 rounded-lg border border-white/10">
          <Briefcase class="text-emerald-400 w-6 h-6 shrink-0" />
          <div class="text-left">
            <p class="text-[10px] text-slate-400 uppercase tracking-wider">Bolsa de</p>
            <p class="font-semibold text-[11px] md:text-sm">Empleo Garantizada</p>
          </div>
        </div>
        <div class="flex items-center gap-3 bg-navy-light/50 p-3 rounded-lg border border-white/10">
          <GraduationCap class="text-gold w-6 h-6 shrink-0" />
          <div class="text-left">
            <p class="text-[10px] text-slate-400 uppercase tracking-wider">Clases</p>
            <p class="font-semibold text-[11px] md:text-sm">100% Online + Tutores</p>
          </div>
        </div>
      </div>
      
      <!-- Duration & Flexibility Info -->
      <div class="flex flex-nowrap gap-2 md:gap-3 pt-2 justify-center md:justify-start overflow-visible">
        <div class="inline-flex items-center gap-1.5 md:gap-2 bg-emerald-500/20 backdrop-blur-sm px-3 py-1.5 md:px-4 md:py-2 rounded-full border border-emerald-400/30 flex-shrink-0">
          <Timer class="w-3.5 h-3.5 md:w-4 md:h-4 text-emerald-400" />
          <span class="text-[10px] md:text-sm font-semibold text-white">Duración: <span class="text-emerald-300">1 Mes</span></span>
        </div>
        <div class="inline-flex items-center gap-1.5 md:gap-2 bg-blue-500/20 backdrop-blur-sm px-3 py-1.5 md:px-4 md:py-2 rounded-full border border-blue-400/30 flex-shrink-0">
          <Clock class="w-3.5 h-3.5 md:w-4 md:h-4 text-blue-400" />
          <span class="text-[10px] md:text-sm font-semibold text-white">Horarios <span class="text-blue-300">Flexibles</span></span>
        </div>
      </div>
    </div>

    <!-- Right Column: Offer Box -->
    <div 
      x-data="{ 
        prices: { full: 297, optA: 159, optB: 115 }
      }"
      class="bg-white rounded-2xl p-6 md:p-8 shadow-2xl border-4 border-gold/30 relative overflow-hidden transform hover:scale-105 transition-transform duration-300"
    >
      <div class="absolute top-0 right-0 bg-green-600 text-white text-xs font-bold px-3 py-1 rounded-bl-lg">
        -52% OFF
      </div>

      <div class="text-center space-y-4">
        <h3 class="text-navy-light font-bold uppercase tracking-widest text-sm border-b pb-2 mb-4">
          Oferta Cierre de Grupo
        </h3>

        <div class="space-y-3 font-sans">
          <!-- Option 1: Full Payment -->
          <div class="bg-navy-light/10 p-4 rounded-lg border border-navy/10 relative overflow-hidden">
             <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mb-1">Inscripción Regular (Único Pago)</p>
             <p class="text-4xl font-bold text-navy font-serif">$297 <span class="text-lg text-slate-400 font-sans font-normal">USD</span></p>
          </div>

          <!-- Financing Options -->
          <div class="bg-white p-3 rounded-lg border border-slate-200">
            <p class="text-[10px] text-center text-slate-400 font-bold uppercase tracking-widest mb-3 border-b border-slate-100 pb-1">Financiamiento Especial</p>
            
            <div class="grid grid-cols-2 gap-3">
              <div class="text-center p-3 bg-slate-50 rounded-xl border border-slate-100 shadow-inner">
                <p class="text-[10px] text-slate-400 uppercase font-bold mb-1">Opción A (2 Cuotas)</p>
                <div class="flex items-baseline justify-center gap-0.5">
                  <span class="text-sm text-navy font-bold">$</span>
                  <span class="text-2xl font-bold text-navy font-serif">159</span>
                </div>
                <p class="text-[9px] text-slate-500 leading-tight mb-2">Cuota Inicial</p>
              </div>
              <div class="text-center p-3 bg-slate-50 rounded-xl border border-slate-100 shadow-inner">
                <p class="text-[10px] text-slate-400 uppercase font-bold mb-1">Opción B (3 Cuotas)</p>
                <div class="flex items-baseline justify-center gap-0.5">
                  <span class="text-sm text-navy font-bold">$</span>
                  <span class="text-2xl font-bold text-navy font-serif">115</span>
                </div>
                <p class="text-[9px] text-slate-500 leading-tight mb-2">Cuota Inicial</p>
              </div>
            </div>
            
            <!-- Elegant BCV Rate Display Removed -->
          </div>
        </div>

        <!-- Evergreen Countdown -->
        <div 
          x-data="countdownTimer()"
          x-init="initTimer()"
          class="bg-navy rounded-xl p-4 mt-4 shadow-inner"
        >
          <p class="text-[10px] text-center mb-2 text-slate-400 uppercase tracking-widest">Inscripciones abiertas hasta:</p>
          <div class="flex justify-center gap-4 text-center font-mono">
             <div>
               <span class="text-2xl font-bold text-gold" x-text="format(hours)">47</span>
               <p class="text-[9px] uppercase text-slate-500">Horas</p>
             </div>
             <span class="text-2xl text-slate-700">:</span>
             <div>
               <span class="text-2xl font-bold text-gold" x-text="format(minutes)">59</span>
               <p class="text-[9px] uppercase text-slate-500">Min</p>
             </div>
             <span class="text-2xl text-slate-700">:</span>
             <div>
               <span class="text-2xl font-bold text-gold" x-text="format(seconds)">59</span>
               <p class="text-[9px] uppercase text-slate-500">Seg</p>
             </div>
          </div>
        </div>

        <a href="/checkout" onclick="trackInitiateCheckout()" class="block w-full bg-emerald-500 hover:bg-emerald-600 text-white font-bold text-lg py-4 rounded-xl shadow-lg hover:shadow-emerald-500/30 transition-all mt-6 uppercase tracking-tight transform hover:scale-[1.02] active:scale-[0.98]">
          ¡Inscribirme Ahora!
        </a>

        <!-- Payment Methods -->
        <div class="mt-6 pt-6 border-t border-slate-100">
          <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mb-3">Paga seguro con:</p>
          <div class="flex flex-nowrap justify-center gap-4 opacity-70 grayscale hover:grayscale-0 transition-all duration-500 overflow-visible">
            <div class="flex flex-col items-center gap-1">
              <div class="h-6 md:h-8 flex items-center justify-center">
                <span class="text-xl md:text-2xl font-bold text-navy">Stripe</span>
              </div>
              <span class="text-[7px] md:text-[8px] font-bold text-slate-500 text-center">Tarjetas de Crédito / Débito</span>
            </div>
          </div>
        </div>
        
        <p class="text-xs text-center text-slate-400 mt-4">
          <span class="text-emerald-500">🔒 Pago Seguro.</span> Acceso inmediato al Campus Online.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  // Alpine.js component definition (global scope for simplicity in Astro)
  document.addEventListener('alpine:init', () => {
    Alpine.data('countdownTimer', () => ({
      hours: 48,
      minutes: 0,
      seconds: 0,
      totalSeconds: 48 * 3600,
      
      initTimer() {
        const storedTime = localStorage.getItem('osbord_wedding_timer');
        const now = new Date().getTime();
        
        if (storedTime) {
          const { expiry } = JSON.parse(storedTime);
          const remaining = Math.max(0, Math.floor((expiry - now) / 1000));
          
          if (remaining === 0) {
            this.resetTimer();
          } else {
            this.totalSeconds = remaining;
          }
        } else {
          this.resetTimer();
        }

        this.updateDisplay();
        
        setInterval(() => {
          if (this.totalSeconds > 0) {
            this.totalSeconds--;
            this.updateDisplay();
          } else {
            this.resetTimer(); // Loop for evergreen effect
          }
        }, 1000);
      },

      resetTimer() {
        const now = new Date().getTime();
        const expiry = now + (48 * 3600 * 1000);
        localStorage.setItem('osbord_wedding_timer', JSON.stringify({ expiry }));
        this.totalSeconds = 48 * 3600;
      },

      updateDisplay() {
        this.hours = Math.floor(this.totalSeconds / 3600);
        this.minutes = Math.floor((this.totalSeconds % 3600) / 60);
        this.seconds = this.totalSeconds % 60;
      },
      
      format(val) {
        return val.toString().padStart(2, '0');
      }
    }));
  });
</script>

<style>
  @keyframes heartbeat {
    0%, 100% { transform: scale(1); filter: brightness(100%); }
    50% { transform: scale(1.03); filter: brightness(110%); }
  }
  .animate-heartbeat {
    animation: heartbeat 2s infinite ease-in-out;
  }
</style>
